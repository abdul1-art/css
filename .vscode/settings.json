{
  // ==================== EMMET SETTINGS ====================
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.triggerExpansionOnTab": true,
  "emmet.extensionsPath": [
    "${workspaceFolder}/.vscode/snippets"
  ],

  // ==================== FILE SETTINGS ====================
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.encoding": "utf8",
  "files.associations": {
    "*.css": "css",
    "*.html": "html",
    "*.js": "javascript"
  },

  // ==================== EDITOR SETTINGS ====================
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": true,
  "editor.lineNumbers": "on",
  "editor.renderWhitespace": "selection",
  "editor.bracketPairColorization.enabled": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },

  // ==================== CSS SETTINGS ====================
  "css.validate": true,
  "less.validate": true,
  "scss.validate": true,

  // ==================== LIVE SERVER ====================
  "liveServer.settings.CustomBrowser": "chrome",
  "liveServer.settings.port": 5500,
  "liveServer.settings.root": "/",

  // ==================== PATH INTELLISENSE ====================
  "path-intellisense.mappings": {
    "${workspaceFolder}/": "${workspaceFolder}",
    "/": "/"
  },

  // ==================== WORKSPACE SYNC ====================
  "settingsSync.ignoredExtensions": [],

  // ==================== TELEMETRY ====================
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,

  // ==================== KEYBINDINGS ====================
  // Note: User keybindings are stored in keybindings.json
  // This is just workspace-specific settings

  // ==================== SNIPPETS ====================
  "snippets.snippets": {
    "javascript": "${workspaceFolder}/.vscode/snippets/javascript.json",
    "javascriptreact": "${workspaceFolder}/.vscode/snippets/javascript.json",
    "typescript": "${workspaceFolder}/.vscode/snippets/javascript.json",
    "typescriptreact": "${workspaceFolder}/.vscode/snippets/javascript.json",
    "html": "${workspaceFolder}/.vscode/snippets/html.json",
    "css": "${workspaceFolder}/.vscode/snippets/css.json",
    "scss": "${workspaceFolder}/.vscode/snippets/css.json"
  }
}
